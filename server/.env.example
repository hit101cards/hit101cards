# サーバー待ち受けポート (Fly.io 等は自動注入される)
PORT=3001

# CORS 許可オリジン (カンマ区切り)
# 未指定時は localhost と LAN プライベートIP (192.168.x.x / 10.x.x.x) を許可
# 本番例: https://hit101.cards,https://www.hit101.cards
CORS_ORIGINS=

# 永続データ (SQLite, audit.log) を置くディレクトリ
# 未指定時は server/ 直下
# Fly.io で volume を使う場合は /data を指定
# DATA_DIR=/data

# DATA_DIR の既定を上書きしたい場合のみ個別指定可能
# DB_PATH=/data/playerStats.sqlite
# AUDIT_LOG_PATH=/data/audit.log
